#include<stdio.h>
#include<string.h>
int main()
{
    char string[50];
    char reverse_string[50];
    printf("The string = ");
    gets(string);
    //char reverse_string[50]=strrev(string);
    strcpy(reverse_string,string);
    strrev(reverse_string);
    if(strcmp(string,reverse_string)==0)
    {
        printf("The given string is a palindrome");
    }
    else
    {
        printf("Not palindrome");
    }
    return 0;
}
