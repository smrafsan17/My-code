/*write a c program to calculate and print the sum of N natural numbers.
If the user gets a negative input,he/she will terminate the running task.*/

#include<stdio.h>
int main()
{
    int N,sum=0;
    scanf("%d",&N);
    for(int i=0;i<=N;i++)
    {
        if(N<0)
        {
            break;
        }
        sum+=i;
    }
    printf("%d",sum);

    return 0;
}
