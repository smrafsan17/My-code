/*write a c program to calculate and print the sum of N natural numbers.
If the user gets a negative input,he/she will skip that value
 and continue the running task.*/

 #include<stdio.h>
 int main()
 {
     int N,sum=0,i;
     scanf("%d",&N);
     int array[N];
     for(i=0;i<N;i++)
     {
         scanf("%d",&array[i]);

         if(array[i]<0)
         {
             continue;
         }
         sum+=array[i];

     }
     printf("%d",sum);

     return 0;
 }
