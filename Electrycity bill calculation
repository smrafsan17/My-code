/*calcalute the total electrocity bill,first 50 per unit 0.50tk, next 100 per unit 0.75tk,
next 100 per unit 1.20tk,next per unit 1.50tk and 20% vat of bill*/

#include<stdio.h>
int main()
{
    float unit,bill=0,total_bill=0;
    printf("unit=");
    scanf("%f",&unit);
    if (unit<=50)
    {
        bill=unit*0.50;
    }
    else if (unit>50 && unit<=150)
    {
        bill=(50*0.50)+ (unit-50)*0.75;
    }
    else if (unit>150 && unit<=250)
    {
        bill=(50*0.50)+ (100*0.75)+(unit-150)*1.20;
    }
    else
    {
        bill=(50*0.50)+ (100*0.75)+(100*1.20)+(unit-250)*1.5;
    }
    printf("Bill is %.2f\n",bill);
    total_bill=bill+(bill*0.20);
    printf("Total Bill with 20% vat %.2f\n",total_bill);

    return 0;

}
